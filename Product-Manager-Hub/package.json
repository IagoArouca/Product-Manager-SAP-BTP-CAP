{
  "name": "cp-products-management",
  "version": "1.0.0",
  "description": "Enterprise Product Management System",
  "license": "UNLICENSED",

  "dependencies": {
    "@sap/cds": "^9",
    "@sap/xsenv": "^5",
    "@sap/xssec": "^4",
    "@cap-js/hana": "^2.7.0",
    "express": "^4"
  },

  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.15.0"
  },

  "scripts": {
    "start": "npx cds-serve",
    "watch": "cds watch",
    "build": "mbt build",
    "deploy": "cf deploy mta_archives/cp-products-management_1.0.0.mtar"
  },

  "cds": {
    "requires": {
      "db": {
        "kind": "hana"
      },
      "auth": {
        "kind": "xsuaa"
      }
    },

    "features": {
      "drafts": true
    },

    "env": {
      "production": {
        "db": "hana"
      }
    }
  },

  "workspaces": [
    "app/*"
  ]
}