{
  "xsappname": "cp_products_v3",
  "tenant-mode": "dedicated",
  "description": "Configuração de Segurança - Enterprise CP Products",
  "scopes": [
    {
      "name": "$XSAPPNAME.admin",
      "description": "Administrador do Sistema"
    },
    {
      "name": "$XSAPPNAME.user",
      "description": "Usuário Autenticado"
    }
  ],
  "role-templates": [
    {
      "name": "admin",
      "description": "Privilégios de Administrador",
      "scope-references": [
        "$XSAPPNAME.admin"
      ]
    },
    {
      "name": "authenticated-user",
      "description": "Privilégios de Usuário Autenticado",
      "scope-references": [
        "$XSAPPNAME.user"
      ]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com/**",
      "https://*.launchpad.cfapps.us10-001.hana.ondemand.com/**",
      "https://*.ondemand.com/**"
    ]
  }
}